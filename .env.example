# ============================================================
# RAG Chatbot - Environment Variables
# ============================================================
# Copy file ini menjadi .env dan isi API Key kamu:
#   cp .env.example .env

# --- Groq API Key ---
# Dapatkan API Key gratis di: https://console.groq.com/keys
# Groq menyediakan akses cepat ke model Llama 3 secara gratis!
GROQ_API_KEY=your_groq_api_key_here
